{
  "manifest_version": 3,
  "name": "Workspace Capture (MVP)",
  "version": "0.0.1",
  "description": "Scaffold extension for capturing shopping product images.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ]
}
