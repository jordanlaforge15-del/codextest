{
  "manifest_version": 3,
  "name": "Workspace Capture (MVP)",
  "version": "0.0.1",
  "description": "Capture webpage images and save them to a workspace.",
  "permissions": ["activeTab", "contextMenus", "notifications", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
