FROM node:20

WORKDIR /workspace/codextest

RUN apt-get update \
    && apt-get install -y --no-install-recommends bubblewrap \
    && rm -rf /var/lib/apt/lists/*

# Install Codex CLI in the development container.
RUN npm install -g @openai/codex

# Keep the container running for interactive Codex/dev shell usage.
CMD ["sleep", "infinity"]
